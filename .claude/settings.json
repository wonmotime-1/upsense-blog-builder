{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Claude Code blog builder hooks — auto-run quality and duplicate check on post.md write/edit",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hook-post-write.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hook-post-write.js"
          }
        ]
      }
    ]
  }
}
